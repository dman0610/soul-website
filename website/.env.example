# ── Botpress ── server-side only, never in client components ──────────────────
# Keys are server-side only — never import these in "use client" components.
# Get these from: Botpress Cloud → your bot → Integrations → HTTP Integration
# Add production values in: Vercel → Settings → Environment Variables

# Soul AI assistant (Soul landing page chatbot)
BOTPRESS_SOUL_WEBHOOK_URL=
BOTPRESS_SOUL_TOKEN=

# Maui Snorkel Co. bot
BOTPRESS_SNORKEL_WEBHOOK_URL=
BOTPRESS_SNORKEL_TOKEN=

# Maui Air Tours bot
BOTPRESS_HELI_WEBHOOK_URL=
BOTPRESS_HELI_TOKEN=

# ── Booking Integration (future) ──────────────────────────────────────────────
# Connect FareHarbor, Square, Bokun, Checkfront, etc.
# See src/app/api/bookings/route.ts for implementation notes.
# BOOKING_API_KEY=
# BOOKING_API_URL=
